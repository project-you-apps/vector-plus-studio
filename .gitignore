# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# User data (cartridges contain personal documents + generated caches).
# Hardened 2026-05-05 to also catch nested subdirs (e.g. archive folders
# under cartridges/ that may contain personal session transcripts).
# 2026-07-11: catch-all added — some subdirs (uploads/, archive/, test_carts/)
# held file types not covered by the extension list below.
cartridges/*
cartridges/**/*.pkl
cartridges/**/*.npy
cartridges/**/*.npz
cartridges/**/*.json
cartridges/**/*.txt
cartridges/**/*.jsonl
cartridges/**/*.db
cartridges/**/*.db-*
cartridges/**/*.cart
cartridges/**/claude_sessions*
!cartridges/.gitkeep

# Sample data - allow small demo cartridges
!sample_data/.gitkeep

# Session transcripts / memory artifacts — never commit, anywhere in tree
**/claude_sessions*
**/session_memory*
**/session-memory*
**/memory_keys*

# Internal docs — devlogs, planning, and pre-scope artifacts contain
# strategic positioning, calibration quotes, and other content that
# should not be in a public repo. Maintained in the local-only outer
# project-you tree at docs/vps-internal/ instead. Andy 2026-05-10.
docs/DEVLOG.md
docs/DEVLOG-*.md
docs/CARTBUILDER-PORT-PLAN.md
docs/OAUTH-PRE-SCOPE.md
docs/*-PRE-SCOPE.md
docs/*-PLAN.md
docs/*-SCOPE.md
docs/internal/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Virtual environments
venv/
.venv/

# Secrets
.env
.env.*
*.pem
*.key

# Node
node_modules/
frontend/dist/
