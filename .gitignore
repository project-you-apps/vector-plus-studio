# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# User data (cartridges contain personal documents + generated caches).
# Hardened 2026-05-05 to also catch nested subdirs (e.g. archive folders
# under cartridges/ that may contain personal session transcripts).
cartridges/**/*.pkl
cartridges/**/*.npy
cartridges/**/*.npz
cartridges/**/*.json
cartridges/**/*.txt
cartridges/**/*.jsonl
cartridges/**/*.db
cartridges/**/*.db-*
cartridges/**/*.cart
cartridges/**/claude_sessions*
!cartridges/.gitkeep

# Sample data - allow small demo cartridges
!sample_data/.gitkeep

# Session transcripts / memory artifacts — never commit, anywhere in tree
**/claude_sessions*
**/session_memory*
**/session-memory*
**/memory_keys*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Virtual environments
venv/
.venv/

# Secrets
.env
.env.*
*.pem
*.key

# Node
node_modules/
frontend/dist/
